{
  "swagger": "2.0",
  "info": {
    "title": "Contacts API",
    "description": "API documentation for the CSE 341 Contacts project",
    "version": "1.0.0"
  },
  "host": "cse341-contacts-project-xld7.onrender.com",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "paths": {
    "/": {
      "get": {
        "description": "",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/contacts/": {
      "get": {
        "tags": [
          "Contacts"
        ],
        "summary": "Get all contacts",
        "description": "Returns all contacts stored in the MongoDB contacts collection.",
        "responses": {
          "200": {
            "description": "Contacts retrieved successfully",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "_id": {
                    "type": "string",
                    "example": "6a4bda3af63f5b193b8f3be0"
                  },
                  "firstName": {
                    "type": "string",
                    "example": "John"
                  },
                  "lastName": {
                    "type": "string",
                    "example": "Doe"
                  },
                  "email": {
                    "type": "string",
                    "example": "john.doe@email.com"
                  },
                  "favoriteColor": {
                    "type": "string",
                    "example": "Blue"
                  },
                  "birthday": {
                    "type": "string",
                    "example": "1992-05-15"
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "Error getting contacts"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Contacts"
        ],
        "summary": "Create a new contact",
        "description": "Creates a new contact in the MongoDB contacts collection.",
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Contact information",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "firstName": {
                  "type": "string",
                  "example": "Diana"
                },
                "lastName": {
                  "type": "string",
                  "example": "Prince"
                },
                "email": {
                  "type": "string",
                  "example": "diana.prince@themyscira.com"
                },
                "favoriteColor": {
                  "type": "string",
                  "example": "Gold"
                },
                "birthday": {
                  "type": "string",
                  "example": "1985-03-22"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Contact created successfully",
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "6a562e33a3af557c9bfb4636"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "All fields are required"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "Error creating contact"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "tags": [
          "Contacts"
        ],
        "summary": "Get contact by ID",
        "description": "Returns a single contact that matches the specified MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the contact"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact found successfully",
            "schema": {
              "type": "object",
              "properties": {
                "_id": {
                  "type": "string",
                  "example": "6a4bda3af63f5b193b8f3be0"
                },
                "firstName": {
                  "type": "string",
                  "example": "John"
                },
                "lastName": {
                  "type": "string",
                  "example": "Doe"
                },
                "email": {
                  "type": "string",
                  "example": "john.doe@email.com"
                },
                "favoriteColor": {
                  "type": "string",
                  "example": "Blue"
                },
                "birthday": {
                  "type": "string",
                  "example": "1992-05-15"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "404": {
            "description": "Contact not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "put": {
        "tags": [
          "Contacts"
        ],
        "summary": "Update a contact",
        "description": "Updates an existing contact using its MongoDB ObjectId.",
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the contact"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Updated contact information",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "firstName": {
                  "type": "string",
                  "example": "Bruce"
                },
                "lastName": {
                  "type": "string",
                  "example": "Wayne"
                },
                "email": {
                  "type": "string",
                  "example": "bruce.wayne@wayneenterprises.com"
                },
                "favoriteColor": {
                  "type": "string",
                  "example": "Dark Gray"
                },
                "birthday": {
                  "type": "string",
                  "example": "1978-02-19"
                }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Contact updated successfully"
          },
          "400": {
            "description": "Missing required fields"
          },
          "404": {
            "description": "Contact not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "delete": {
        "tags": [
          "Contacts"
        ],
        "summary": "Delete a contact",
        "description": "Deletes a contact from the MongoDB contacts collection.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the contact"
          }
        ],
        "responses": {
          "204": {
            "description": "Contact deleted successfully"
          },
          "404": {
            "description": "Contact not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  }
}